{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "dockerfile": "*compose.yml, *compose.yaml",
    "license": "license.md, license.txt",
    ".jsx": "*.jsx, *.tsx, *.js, *.ts, *.cjs, *.mjs",
    "package-lock.json": "yarn.lock, pnpm-lock.yaml, bun.lockb",
    "package.json": ".jsx, package-lock.json, tsconfig.json, jsconfig.json",
    ".json": ".xml, .sql",
    ".yml": ".yaml",
    ".html": ".css",
    ".editorconfig": ".config",
    ".md": ".mdx",
    ".gitignore": ".git*",
    ".cs": ".csproj, .sln",
    ".zip": ".7z, .appimage, .aur, .bz2, .deb, .exe, .flatpak, .gz, .iso, .obs, .pkg, .ppa, .rar, .rpm, .snap, .tar, .tgz, .vsix, .xz, .zst",
    ".java": ".class, .ear, .jar, .jmod, .jsp, .mf, .properties, .war, manifest, mvnw*, pom.xml, .gradle, gradlew*",
    ".doc": ".docm, .docx, .dot, .dotm, .dotx, .gdoc, .odt, .ott, .pages",
    ".ppt": ".pptx, .pps, .ppsx, .pot, .potx, .otp, .odp, .key",
    ".xls": ".xlsx, .xlsb, .xlsm, .xltm, .xltx, .ods, .ots, .numbers, .gsheet",
    ".mp3": ".ogg, .wav",
    ".png": ".avif, .bmp, .gif, .heic, .heif, .icns, .ico, .jpeg, .jpg, .tiff, .webp",
    ".mp4": ".avi, .flv, .m4v, .mkv, .mov, .mpeg, .mpg, .webm, .wmv",
    ".tool-versions": "*version, *mrc, .sdkmanrc, .ruby-gemset",
    ".sh": ".bash*, .fish, .zsh",
    ".bat": ".ps*, .cmd",
  }
}